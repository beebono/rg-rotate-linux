	scene-frequency {
		compatible = "sprd,ddr-dvfs";
		freq-num = <0x08>;
		phandle = <0x17c>;
	};

	sprd-sensorhub {
		compatible = "sprd,sharkl5Pro-sensorhub\0sprd,sensor-hub";
	};

	thermal-zones {
		phandle = <0x17d>;

		soc-thmzone {
			polling-delay-passive = <0x64>;
			polling-delay = <0x3e8>;
			sustainable-power = <0x16a8>;
			thermal-sensors = <0xc2 0x00>;
			phandle = <0x17e>;

			trips {

				trip-point@0 {
					temperature = <0x11170>;
					hysteresis = <0x3e8>;
					type = "passive";
					phandle = <0x17f>;
				};

				trip-point@1 {
					temperature = <0x14c08>;
					hysteresis = <0x3e8>;
					type = "passive";
					phandle = <0xc3>;
				};

				soc_crit {
					temperature = <0x1adb0>;
					hysteresis = <0x7d0>;
					type = "critical";
					phandle = <0x180>;
				};
			};

			cooling-maps {

				map0 {
					trip = <0xc3>;
					contribution = <0x400>;
					cooling-device = <0x91 0xffffffff 0xffffffff>;
				};

				map1 {
					trip = <0xc3>;
					contribution = <0x2aa>;
					cooling-device = <0x9d 0xffffffff 0xffffffff>;
				};

				map2 {
					trip = <0xc3>;
					contribution = <0x400>;
					cooling-device = <0xc4 0xffffffff 0xffffffff>;
				};

				map3 {
					trip = <0xc3>;
