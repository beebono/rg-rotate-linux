[submodule "tools/pac-extractor"]
	path = tools/pac-extractor
	url = https://github.com/bismoy-bot/PAC-Extractor.git
[submodule "vendor/android-kernel-ums512"]
	path = vendor/android-kernel-ums512
	url = https://github.com/Veynamer/android_kernel_unisoc_ums512.git
	branch = Dev-infinix-x6816d
[submodule "src/busybox"]
	path = src/busybox
	url = https://github.com/mirror/busybox.git
[submodule "vendor/spl-uboot-patch"]
	path = vendor/spl-uboot-patch
	url = https://github.com/TheGammaSqueeze/UnisocBypass.git
[submodule "vendor/bootloader-unlock"]
	path = vendor/bootloader-unlock
	url = https://github.com/patrislav1/unisoc-unlock.git
[submodule "vendor/u-boot-ums512"]
	path = src/u-boot
	url = https://github.com/beebono/u-boot-ums512.git
	branch = main
[submodule "vendor/linux-kernel-5-4-ums512"]
	path = vendor/linux-kernel-5-4-ums512
	url = https://github.com/marohinmark/kernel_ums512_5.4.git
[submodule "src/linux-7-1-sprd"]
	path = src/linux-7-1-sprd
